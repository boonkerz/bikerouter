default_platform(:ios)

# Read the version string ("X.Y.Z") and the build number ("N") from the
# Flutter pubspec.yaml so they are the single source of truth across iOS
# and Android. Format in pubspec is `version: X.Y.Z+N`.
def pubspec_version_components
  pubspec = File.read("../../pubspec.yaml")
  match = pubspec.match(/^version:\s*([0-9]+(?:\.[0-9]+)*)(?:\+([0-9]+))?/)
  raise "could not parse version from pubspec.yaml" unless match
  [match[1], match[2] || "1"]
end

platform :ios do
  desc "Smoke-test the App Store Connect API key without touching builds"
  lane :auth_check do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false,
    )
    # The cheapest API call — just lists apps the key can see. If this
    # fails, the credentials are wrong before any signing comes into play.
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key: Base64.decode64(ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]),
    )
    apps = Spaceship::ConnectAPI::App.all(limit: 5)
    UI.success "✓ API key works — visible apps: #{apps.map(&:bundle_id).join(', ')}"
  end


  desc "Build the iOS IPA via Flutter and upload to TestFlight"
  lane :release do
    # The secret is stored as base64-encoded contents of the .p8 file —
    # see SELFHOSTED-CI.md step 1. Single-line value survives paste in
    # the GitHub Actions UI without whitespace corruption that broke
    # the raw-PEM variant.
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true,
      in_house: false,
    )

    # The iOS Distribution certificate (private key included) is imported
    # into a throwaway keychain by the CI step *before* fastlane runs — see
    # .github/workflows/release.yml "Import signing certificate". Hosted
    # runners are ephemeral, so we never let fastlane mint a new cert (`cert`)
    # — that would burn through Apple's 3-cert limit and leave the private key
    # behind on a machine we throw away. The .p12 is the single source of the
    # signing identity.
    team_id = "933ZZXVE7E"
    app_id   = "com.thomaspeterson.bikerouter"
    watch_id = "com.thomaspeterson.bikerouter.watchkitapp"

    # App Store provisioning profiles for both bundles (the iOS app and the
    # embedded Watch companion). `sigh` downloads/creates them via the API key
    # and installs them; readonly:false lets it create one if missing.
    # Capture each profile's name from lane_context right after its sigh call
    # (SIGH_NAME is overwritten by the next sigh, so read it immediately).
    sigh(api_key: api_key, app_identifier: app_id,   platform: "ios", readonly: false)
    app_profile = lane_context[SharedValues::SIGH_NAME]
    sigh(api_key: api_key, app_identifier: watch_id, platform: "ios", readonly: false)
    watch_profile = lane_context[SharedValues::SIGH_NAME]
    UI.user_error!("sigh did not return profile names") unless app_profile && watch_profile
    UI.message "Using profiles: app='#{app_profile}', watch='#{watch_profile}'"

    # Flip both targets from automatic to manual signing so the archive uses
    # the imported distribution cert + the profiles sigh just installed. The
    # Xcode target name for the watch is "WegwieselWatch Watch App" even though
    # its bundle id is …watchkitapp.
    update_code_signing_settings(
      use_automatic_signing: false, path: "../Runner.xcodeproj",
      team_id: team_id, code_sign_identity: "Apple Distribution",
      bundle_identifier: app_id, profile_name: app_profile, targets: ["Runner"],
    )
    update_code_signing_settings(
      use_automatic_signing: false, path: "../Runner.xcodeproj",
      team_id: team_id, code_sign_identity: "Apple Distribution",
      bundle_identifier: watch_id, profile_name: watch_profile,
      targets: ["WegwieselWatch Watch App"],
    )

    # ExportOptions.plist for `flutter build ipa` — manual app-store export
    # mapping each bundle id to its profile.
    export_opts = File.expand_path("../ExportOptions.plist", __dir__)
    File.write(export_opts, <<~PLIST)
      <?xml version="1.0" encoding="UTF-8"?>
      <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
      <plist version="1.0">
      <dict>
        <key>method</key><string>app-store</string>
        <key>teamID</key><string>#{team_id}</string>
        <key>signingStyle</key><string>manual</string>
        <key>signingCertificate</key><string>Apple Distribution</string>
        <key>provisioningProfiles</key>
        <dict>
          <key>#{app_id}</key><string>#{app_profile}</string>
          <key>#{watch_id}</key><string>#{watch_profile}</string>
        </dict>
        <key>uploadSymbols</key><true/>
        <key>uploadBitcode</key><false/>
      </dict>
      </plist>
    PLIST

    version_name, build_number = pubspec_version_components
    UI.message "Building iOS #{version_name}+#{build_number}"

    # `flutter build ipa` handles the Watch target automatically because
    # it's embedded in the Runner Xcode scheme. The build-number override
    # ensures we use the pubspec value rather than whatever Xcode would
    # auto-derive.
    sh "cd ../.. && flutter build ipa --release " \
       "--build-name=#{version_name} " \
       "--build-number=#{build_number} " \
       "--export-options-plist=#{export_opts}"

    ipa_path = Dir["#{ENV['GITHUB_WORKSPACE'] || '../..'}/app/build/ios/ipa/*.ipa"].first
    ipa_path ||= Dir["../build/ios/ipa/*.ipa"].first
    UI.user_error!("no IPA found after build") unless ipa_path

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      changelog: "Automated build #{version_name}+#{build_number}",
    )
  end
end
