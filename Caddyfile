wegwiesel.app {
	# BRouter API
	handle /brouter* {
		reverse_proxy brouter:17777
	}

	# Overpass API (eigener Server)
	handle_path /overpass/* {
		reverse_proxy overpass:80
	}

	# Offline routing segment files
	handle_path /segments/* {
		root * /srv/segments
		file_server
	}

	# Feedback Service
	redir /feedback /feedback/ 301
	handle /api/feedback* {
		reverse_proxy feedback:8080
	}
	handle_path /feedback/* {
		reverse_proxy feedback:8080
	}

	# Share Service (Garmin sync codes + public route library)
	handle /api/share* {
		reverse_proxy share:8080
	}
	handle /api/library* {
		reverse_proxy share:8080
	}
	handle /api/heatmap* {
		reverse_proxy share:8080
	}

	# Live tracking
	handle /api/track* {
		reverse_proxy tracking:8080
	}
	handle /track/* {
		reverse_proxy tracking:8080
	}

	# AFIR ad-hoc charging prices (bbox API, Mobilithek feed)
	handle /api/charging-prices* {
		reverse_proxy charging-prices:8080
	}

	# Charging-card tariff table (hand-maintained JSON)
	handle /api/charging-tariffs* {
		reverse_proxy charging-prices:8080
	}

	# Flutter Web App
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}

# Redirects auf Hauptdomain
wegwiesel.de, www.wegwiesel.de, wegwiesel.com, www.wegwiesel.com, www.wegwiesel.app {
	redir https://wegwiesel.app{uri} permanent
}
