wegwiesel.app {
	# BRouter API
	handle /brouter* {
		reverse_proxy brouter:17777
	}

	# Flutter Web App
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}

# Redirects auf Hauptdomain
wegwiesel.de, www.wegwiesel.de, wegwiesel.com, www.wegwiesel.com, www.wegwiesel.app {
	redir https://wegwiesel.app{uri} permanent
}

# Alte Domain: API weiterhin erreichbar (für bereits installierte App-Versionen),
# Webseite leitet auf neue Domain um
bikerouter.thomas-peterson.de {
	handle /brouter* {
		reverse_proxy brouter:17777
	}
	handle {
		redir https://wegwiesel.app{uri} permanent
	}
}
